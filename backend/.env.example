# Example environment configuration for Job Portal Backend
# Copy this file to .env and fill in real values. Do NOT commit your .env.

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=jobportal
DB_USER=postgres
DB_PASSWORD=change_me

# JWT
JWT_SECRET=please_replace_with_a_strong_random_secret

# Server
PORT=5000
NODE_ENV=development

# SMTP (optional, for recruiter emails)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
SMTP_SECURE=false
SMTP_FROM="Job Portal <no-reply@example.com>"

# Optional third-party keys
# OPENAI_API_KEY=
